modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NEXT_PUBLIC_API_URL = ""
UPLOADS_DIR = "/tmp/uploads"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && USE_SDK_POOL=1 python -m agent.run & sleep 3 && cd /home/runner/workspace/frontend && npm run dev:replit"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PYTHONUNBUFFERED=1 USE_SDK_POOL=1 python -m agent.run 2>&1 & sleep 5 && cd frontend && npm run start:replit"]
build = ["bash", "-c", "pip install -r agent/requirements.txt && pip install -e ./aind-data-mcp && cd frontend && npm install && npm run build"]
